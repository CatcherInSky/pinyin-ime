# Vite bundles `site/vite.config.ts` under root `node_modules/.vite-temp/`; Node resolves
# imports from `root/node_modules` (one level up from `.vite-temp`). Root devDependencies
# plus hoisting keep `vite` / `@vitejs/plugin-react` visible there under pnpm.
public-hoist-pattern[]=@vitejs/plugin-react
public-hoist-pattern[]=vite
shamefully-hoist=true

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "pinyin-ime/dictionary/google_pinyin_dict": [
        "./dictionary/google_pinyin_dict.ts"
      ],
      "pinyin-ime/dictionary/dota2_pinyin_dict": [
        "./dictionary/dota2_pinyin_dict.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "dictionary/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "tsup.config.ts",
    "vitest.config.ts"
  ]
}

{
  "name": "pinyin-ime",
  "version": "0.8.1",
  "description": "拼音转汉字输入法能力：在无法使用系统输入法的场景使用，通过候选框选词上屏",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dictionary/dota2_pinyin_dict": {
      "import": "./dist/dictionary/dota2_pinyin_dict.js",
      "types": "./dist/dictionary/dota2_pinyin_dict.d.ts"
    },
    "./dictionary/google_pinyin_dict": {
      "import": "./dist/dictionary/google_pinyin_dict.js",
      "types": "./dist/dictionary/google_pinyin_dict.d.ts"
    },
    "./pinyin-ime.css": "./dist/pinyin-ime.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/dictionary/dota2_pinyin_dict.js",
    "./dist/dictionary/google_pinyin_dict.js",
    "./dist/pinyin-ime.css"
  ],
  "scripts": {
    "dev": "pnpm run build:watch",
    "prebuild": "node scripts/embed-css.mjs",
    "build": "tsup",
    "build:watch": "tsup --watch --no-clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "site:dev": "pnpm --filter pinyin-ime-site dev",
    "site:dev:hot": "pnpm --filter pinyin-ime-site dev --config vite.local.config.ts",
    "site:dev:npm": "pnpm --filter pinyin-ime-site dev --config vite.dist.config.ts",
    "site:build": "pnpm run build && pnpm --filter pinyin-ime-site build --mode production",
    "publish:npm": "pnpm publish --no-git-checks --registry https://registry.npmjs.org/"
  },
  "keywords": [
    "pinyin",
    "ime",
    "input",
    "chinese",
    "input-method",
    "web-components",
    "lit"
  ],
  "license": "MIT",
  "author": "catcherinsky",
  "repository": {
    "type": "git",
    "url": "https://github.com/catcherinsky/pinyin-ime.git"
  },
  "bugs": {
    "url": "https://github.com/catcherinsky/pinyin-ime/issues"
  },
  "homepage": "https://github.com/catcherinsky/pinyin-ime#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "lit": "^3.2.1",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.5"
  },
  "workspaces": ["site"]
}
